# CouncilCast Studio API keys
# Copy this file to .env and replace the placeholder values below.
# WARNING: .env should never be committed to git (it is already in .gitignore).

# Required for Real Mode (OpenAI LLM for brief/discussion/script generation).
# Leave empty to use Demo Mode instead.
COUNCILCAST_LLM_API_KEY=

# Optional — for OpenAI TTS audio narration.
# If left empty, the app tries gTTS as a free fallback, or skips audio.
# You can use the same OpenAI key as COUNCILCAST_LLM_API_KEY here.
COUNCILCAST_TTS_API_KEY=
